#!/usr/bin/env python3
"""
Simple Singularity/Apptainer .def formatter.
- Splits into sections beginning with lines that start with '%'.
- Runs `shfmt` on shell-like sections (if available).
- Normalizes whitespace for %files and %labels sections (non-destructive).
- Preserves other sections/comments as-is.
Reads from stdin, writes to stdout.
"""

import re
import subprocess
import sys
from shutil import which
from typing import Optional, Tuple

SECTION_RE = re.compile(r"^(%[^\s].*)$")

SHELL_SECTIONS = {
    "post",
    "runscript",
    "test",
    "setup",
    "environment",
    "startscript",
    "postsetup",
}


def parse_sections(text_lines: list[str]) -> list[Tuple[Optional[str], list[str]]]:
    """
    Parses input lines into headers and bodies based on section definitions.

    Args:
        text_lines: A list of raw strings from the definition file.

    Returns:
        A list of tuples where each tuple contains the section header string
        (or None for the preamble) and a list of body lines.
    """
    parsed_parts: list[Tuple[Optional[str], list[str]]] = []
    current_header: Optional[str] = None
    current_body: list[str] = []

    def flush_section() -> None:
        """Appends the current section to the parsed parts and resets the body."""
        nonlocal current_header, current_body
        if current_header is None and not current_body:
            return
        parsed_parts.append((current_header, current_body.copy()))
        current_body.clear()

    for line in text_lines:
        match = SECTION_RE.match(line)
        if match:
            flush_section()
            current_header = match.group(1).rstrip()
        else:
            current_body.append(line.rstrip())

    flush_section()
    return parsed_parts


def run_shfmt(script_content: str) -> Optional[str]:
    """
    Formats a shell script section using the external 'shfmt' utility.

    Args:
        script_content: The raw shell script string.

    Returns:
        The formatted shell script string, or None if formatting fails or
        shfmt is unavailable.
    """
    shfmt_path = which("shfmt")
    if not shfmt_path:
        return None

    try:
        process = subprocess.run(
            [shfmt_path, "-i", "2", "-ci"],
            input=script_content,
            text=True,
            capture_output=True,
            timeout=5,
        )

        if process.returncode == 0:
            return process.stdout
        return None
    except Exception:
        return None


def collapse_blank_lines(lines: list[str]) -> list[str]:
    """
    Compresses consecutive blank lines into a single blank line.
    Leading and trailing blank lines are removed.

    Args:
        lines: A list of string lines to process.

    Returns:
        A new list of strings with normalized blank spacing.
    """
    out: list[str] = []
    prev_blank: bool = False

    for line in lines:
        is_blank = line.strip() == ""
        if is_blank:
            if not prev_blank:
                out.append("")
            prev_blank = True
        else:
            out.append(line.rstrip())
            prev_blank = False

    while out and out[0] == "":
        out.pop(0)

    while out and out[-1] == "":
        out.pop()

    return out


def format_definition_file(text_lines: list[str]) -> str:
    """
    Applies standard formatting rules to the parsed Singularity definition file.

    Args:
        text_lines: The raw lines read from the input stream.

    Returns:
        The fully formatted string representation of the definition file.
    """
    parsed_parts = parse_sections(text_lines)
    out_lines: list[str] = []

    for _, (header, body) in enumerate(parsed_parts):
        if header is None:
            collapsed = collapse_blank_lines(body)
            out_lines.extend(collapsed)
            if collapsed and len(parsed_parts) > 1:
                out_lines.append("")
            continue

        out_lines.append(header)
        if any(line.strip() for line in body):
            out_lines.append("")

        secname = header.split()[0][1:].lower()
        body_text = "\n".join(body) + ("\n" if body else "")

        if secname in SHELL_SECTIONS:
            formatted = run_shfmt(body_text)
            if formatted is not None:
                formatted_lines = formatted.rstrip("\n").split("\n")
                formatted_lines = collapse_blank_lines(formatted_lines)
                out_lines.extend(formatted_lines)
                out_lines.append("")
                continue
            else:
                collapsed = collapse_blank_lines(body)
                out_lines.extend(collapsed)
                out_lines.append("")
                continue

        if secname == "files":
            processed_files: list[str] = []
            for line in body:
                if not line.strip() or line.lstrip().startswith("#"):
                    processed_files.append(line)
                else:
                    parts_line = re.split(r"\s+", line.strip(), maxsplit=1)
                    if len(parts_line) == 2:
                        processed_files.append(f"{parts_line[0]} {parts_line[1]}")
                    else:
                        processed_files.append(parts_line[0])

            collapsed_files = collapse_blank_lines(processed_files)
            out_lines.extend(collapsed_files)
            out_lines.append("")
            continue

        if secname == "labels":
            processed_labels: list[str] = []
            for line in body:
                if not line.strip() or line.lstrip().startswith("#"):
                    processed_labels.append(line)
                else:
                    kv = re.split(r"\s+", line.strip(), maxsplit=1)
                    if len(kv) == 2:
                        processed_labels.append(f"{kv[0]} {kv[1]}")
                    else:
                        processed_labels.append(kv[0])

            collapsed_labels = collapse_blank_lines(processed_labels)
            out_lines.extend(collapsed_labels)
            out_lines.append("")
            continue

        collapsed_default = collapse_blank_lines(body)
        out_lines.extend(collapsed_default)
        out_lines.append("")

    # Execute final global cleanup to collapse any accidental multiple blank lines
    final_lines: list[str] = []
    prev_blank: bool = False

    for line in out_lines:
        is_blank = line.strip() == ""
        if is_blank:
            if not prev_blank:
                final_lines.append("")
            prev_blank = True
        else:
            final_lines.append(line.rstrip())
            prev_blank = False

    while final_lines and final_lines[0] == "":
        final_lines.pop(0)

    while final_lines and final_lines[-1] == "":
        final_lines.pop()

    return "\n".join(final_lines) + "\n"


def main() -> None:
    """Entry point for the script reading from standard input."""
    text = sys.stdin.read().splitlines()
    formatted_output = format_definition_file(text)
    sys.stdout.write(formatted_output)


if __name__ == "__main__":
    main()
